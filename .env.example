# Copy this file to .env and fill in your keys.

# At least one model provider key is required.
OPENAI_API_KEY=
GROQ_API_KEY=

# Required for the internet_search tool used by the company-researcher subagent.
TAVILY_API_KEY=

# Optional overrides.
CAREERFORGE_MODEL=openai:gpt-4.1
CAREERFORGE_LOG_LEVEL=INFO
